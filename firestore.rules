rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── SHOWCASE / TALENT FEED ───
    // Students & staff can read all posts, write their own
    match /showcase_posts/{postId} {
      allow read: if true;                          // Public read
      allow create: if request.auth != null         // Logged-in users can post
                    || true;                        // OR allow even without Firebase Auth
      allow update, delete: if request.auth != null;
    }

    // Alias collection (in case code uses 'talent_feed')
    match /talent_feed/{postId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ─── UPLOAD ERROR LOGS ───
    match /upload_errors/{errorId} {
      allow read: if request.auth != null;
      allow create: if true;                        // Always allow error logging
    }

    // ─── SHOWCASE COMMENTS ───
    match /showcase_comments/{commentId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ─── ADMIN SETTINGS (YouTube Token) ───
    match /admin_settings/{docId} {
      allow read: if true;                          // All users need to read token for upload
      allow write: if true;                         // Admin saves token here
    }

    // ─── STAFF / STUDENTS (Custom Password Auth - No Firebase Auth) ───
    match /staff/{staffId} {
      allow read: if true;
      allow write: if true;                         // App uses custom Firestore-based auth
    }
    match /students/{studentId} {
      allow read: if true;
      allow write: if true;                         // App uses custom Firestore-based auth
    }

    // ─── ATTENDANCE ───
    match /attendance_reports/{reportId} {
      allow read: if true;
      allow write: if true;
    }

    // ─── NOTIFICATIONS / NOTICES ───
    match /notifications/{notifId} {
      allow read, write: if true;
    }
    match /notices/{noticeId} {
      allow read, write: if true;
    }

    // ─── FEES ───
    match /fees/{feeId} {
      allow read, write: if true;
    }

    // ─── DEFAULT: Allow all (since app uses custom auth) ───
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
